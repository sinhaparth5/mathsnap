{
  "name": "mathsnap",
  "version": "1.0.8",
  "description": "The goal is to provide a reusable component that abstracts away KaTeX configuration and makes it easy to use",
  "keywords": [
    "katex",
    "latex",
    "maths",
    "equations",
    "react",
    "svelte",
    "vue"
  ],
  "homepage": "https://github.com/sinhaparth5/mathsnap#readme",
  "bugs": {
    "url": "https://github.com/sinhaparth5/mathsnap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinhaparth5/mathsnap.git"
  },
  "license": "MIT",
  "author": "Parth Sinha",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "browser": "dist/browser/mathsnap.esm.js",
  "files": [
    "dist",
    "src/svelte",
    "src/vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.cjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/MathEquation.svelte",
      "import": "./dist/svelte/index.mjs",
      "require": "./dist/svelte/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.cjs"
    },
    "./mathsnap.min.css": "./dist/mathsnap.min.css",
    "./style": "./dist/mathsnap.min.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "node build.js",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "katex": "^0.16.21"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.27.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/katex": "^0.16.7",
    "@types/react": "^19.0.12",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-vue": "^5.2.3",
    "archiver": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "rimraf": "^6.0.1",
    "svelte": "^5.25.3",
    "ts-jest": "^29.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-dts": "^4.5.3",
    "vue": "*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/fileMock.cjs"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx",
            "esModuleInterop": true
          }
        }
      ]
    },
    "extensionsToTreatAsEsm": [],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  }
}
